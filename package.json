{
  "name": "composable-agent-workflow-runtime",
  "version": "0.1.0",
  "description": "Reusable feasibility-aware workflow templates for coding agents.",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "demo": "node --experimental-strip-types demo.ts",
    "demo:feasible": "node --experimental-strip-types demo-feasibility.ts feasible",
    "demo:infeasible": "node --experimental-strip-types demo-feasibility.ts infeasible",
    "demo:code-test-verify": "node --experimental-strip-types cli/run-workflow.ts --template code-test-verify --input inputs/feasible-task.json",
    "demo:code-test-repair-review": "node --experimental-strip-types demo-code-test-repair-review.ts",
    "demo:approved-repair-materialize": "node --experimental-strip-types demo-approved-repair-materialize.ts",
    "workflow": "node --experimental-strip-types cli/run-workflow.ts",
    "workflow:list": "node --experimental-strip-types cli/list-templates.ts",
    "workflow:validate": "node --experimental-strip-types cli/validate-template.ts",
    "workflow:roles": "node --experimental-strip-types cli/list-roles.ts",
    "workflow:create": "node --experimental-strip-types cli/create-template.ts",
    "workflow:inspect": "node --experimental-strip-types cli/inspect-template.ts",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "typecheck": "node --experimental-strip-types scripts/typecheck.ts",
    "opencode:check": "node --experimental-strip-types scripts/opencode-check.ts",
    "policy:audit": "node --experimental-strip-types cli/policy-audit.ts",
    "policy:pending": "node --experimental-strip-types cli/policy-pending.ts",
    "policy:approve": "node --experimental-strip-types cli/policy-approve.ts",
    "policy:reject": "node --experimental-strip-types cli/policy-reject.ts",
    "policy:replay-check": "node --experimental-strip-types cli/policy-replay-check.ts",
    "policy:replay": "node --experimental-strip-types cli/policy-replay.ts",
    "policy:replay-history": "node --experimental-strip-types cli/policy-replay-history.ts",
    "llm:config": "node --experimental-strip-types cli/llm-config.ts",
    "llm:smoke": "node --experimental-strip-types cli/llm-smoke.ts",
    "release:check": "node --experimental-strip-types scripts/release-check.ts",
    "repo:check": "node --experimental-strip-types scripts/repo-check.ts",
    "doctor": "node --experimental-strip-types scripts/doctor.ts",
    "verify": "node --experimental-strip-types scripts/verify.ts"
  }
}
