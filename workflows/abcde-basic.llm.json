{
  "name": "abcde-basic-llm",
  "version": "1.0.0",
  "description": "Opt-in ABCDE workflow using real LLM nodes for thinking roles and mock simulation for safe Executor/Verifier roles.",
  "start": "planner",
  "maxIterations": 6,
  "inputSchema": "TaskBrief",
  "defaultPolicies": {
    "permissionPolicy": {
      "allowWithoutConfirmation": ["edit project files", "create files", "run local tests", "run local demos"],
      "requireConfirmation": ["delete existing project files", "large rewrites", "external paid API calls", "real LLM calls"],
      "forbiddenWithoutExplicitApproval": ["git reset --hard", "git clean -fd", "deploy", "production data changes"]
    },
    "costPolicy": {
      "maxCostLevel": "medium",
      "stopWhen": ["scope too large", "cost high", "risk high", "missing LLM budget approval"],
      "preferredDecisionsWhenOverBudget": ["ask_human", "revise_goal", "stop"]
    },
    "qualityPolicy": {
      "principles": ["quality over speed", "configuration-driven runtime", "schema-validated outputs"],
      "requiredChecks": ["npm run test", "npm run typecheck"],
      "forbiddenShortcuts": ["hardcoded runtime flow", "deleting tests", "swallowing errors", "bypassing SchemaValidator"]
    }
  },
  "nodes": [
    { "rolePreset": "planner", "type": "llm", "retryPolicy": { "maxAttempts": 2, "backoffMs": 100 } },
    { "rolePreset": "debater", "type": "llm", "retryPolicy": { "maxAttempts": 2, "backoffMs": 100 } },
    { "rolePreset": "planner-revision", "type": "llm", "retryPolicy": { "maxAttempts": 2, "backoffMs": 100 } },
    { "rolePreset": "executor", "type": "mock" },
    { "rolePreset": "verifier", "type": "mock" },
    { "rolePreset": "goalkeeper", "type": "llm", "retryPolicy": { "maxAttempts": 2, "backoffMs": 100 } }
  ],
  "edges": [
    { "from": "planner", "to": "debater", "condition": { "type": "always" } },
    { "from": "debater", "to": "plannerRevision", "condition": { "type": "always" } },
    { "from": "plannerRevision", "to": "executor", "condition": { "type": "always" } },
    { "from": "executor", "to": "verifier", "condition": { "type": "always" } },
    { "from": "verifier", "to": "end", "condition": { "type": "equals", "path": "verification.pass", "value": true } },
    { "from": "verifier", "to": "goalkeeper", "condition": { "type": "equals", "path": "verification.pass", "value": false } },
    { "from": "goalkeeper", "to": "plannerRevision", "condition": { "type": "always" } }
  ]
}
