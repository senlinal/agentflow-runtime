{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "agentflow": {
      "type": "local",
      "command": ["node", "--experimental-strip-types", "mcp/agentflow-mcp-server.ts"],
      "enabled": true
    }
  },
  "permission": {
    "bash": "ask",
    "edit": "ask",
    "read": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "external_directory": {
      "*": "ask",
      "~/development/garbage_item_upload/**": "allow",
      "/Users/*/development/garbage_item_upload/**": "allow"
    }
  }
}
